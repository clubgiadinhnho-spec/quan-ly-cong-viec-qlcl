rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Access Control
    match /{document=**} {
      allow read, write, delete: if isAdmin();
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'truong.le@tanphuvietnam.vn' || 
        request.auth.token.email == 'lenhattruong.tpp@gmail.com' ||
        request.auth.token.email == 'lenhattruong.caphef1@gmail.com' ||
        request.auth.token.email == 'club.nhuatanphu@gmail.com' ||
        request.auth.token.email == 'tanphuvietnam.tpp@gmail.com' ||
        request.auth.token.email == 'truongln.tanhongngoc@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'role']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.role in ['Staff', 'Leader', 'Admin'];
    }

    function isValidTask(data) {
      return data.keys().hasAll(['code', 'title', 'assigneeId', 'status']) &&
             data.code is string && data.code.size() <= 50 &&
             data.title is string && data.title.size() <= 500 &&
             data.status in ['IN_PROGRESS', 'PENDING_APPROVAL', 'COMPLETED', 'CANCELLED', 'ON_HOLD'];
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['authorId', 'content', 'timestamp']) &&
             data.authorId is string && data.authorId.size() <= 128 &&
             data.content is string && data.content.size() <= 5000;
    }

    // --- Collections ---

    // 1. User Profiles
    match /user_profiles/{profileId} {
      allow list: if isAdmin();
      allow get: if isSignedIn();
      allow create: if isAdmin() || (isSignedIn() && profileId == request.auth.uid && isValidUser(incoming()));
      allow update: if isAdmin() || (isSignedIn() && profileId == request.auth.uid && isValidUser(incoming()));
    }

    // 2. Extra Users (Auto-registration fallback)
    match /extra_users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && userId == request.auth.uid);
    }

    // 3. Tasks
    match /tasks/{taskId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidTask(incoming());
      allow update: if isSignedIn() && isValidTask(incoming());
      allow delete: if isAdmin();
    }

    // 4. Messages (General Chat)
    match /messages/{msgId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidMessage(incoming()) && incoming().authorId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid && incoming().authorId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // 5. Discussion
    match /discussion_topics/{topicId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /discussion_messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidMessage(incoming()) && incoming().authorId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // 6. Direct Messages
    match /direct_messages/{msgId} {
      allow list: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow get: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
      allow update: if isSignedIn() && (existing().senderId == request.auth.uid || existing().receiverId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // 7. Presence
    match /presence/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && id == request.auth.uid;
    }

    // 8. Reports
    match /report_drafts/{draftId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow write: if isSignedIn() && (isAdmin() || incoming().userId == request.auth.uid);
    }
    match /official_reports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 9. System
    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }


  }
}
