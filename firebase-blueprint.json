{
  "entities": {
    "User": {
      "title": "User",
      "description": "Staff member information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "zalo": { "type": "string" },
        "role": { "type": "string", "enum": ["Staff", "Leader", "Admin"] },
        "companyEmail": { "type": "string" },
        "personalEmail": { "type": "string" },
        "avatar": { "type": "string" },
        "code": { "type": "string" },
        "abbreviation": { "type": "string" },
        "personalNote": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "ACTIVE", "INACTIVE"] },
        "securityQuestion": { "type": "string" },
        "securityAnswer": { "type": "string" },
        "delegatedPermissions": {
          "type": "object",
          "properties": {
            "canCreateTask": { "type": "boolean" },
            "canApproveTask": { "type": "boolean" },
            "canDeleteTask": { "type": "boolean" },
            "canExportExcel": { "type": "boolean" },
            "canImportExcel": { "type": "boolean" },
            "canManageStaff": { "type": "boolean" }
          }
        }
      },
      "required": ["id", "name", "phone", "role", "companyEmail", "personalEmail", "avatar", "code", "abbreviation", "status", "securityQuestion", "securityAnswer"]
    },
    "Message": {
      "title": "Message",
      "description": "Group chat message",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "content", "timestamp"]
    },
    "PrivateMessage": {
      "title": "PrivateMessage",
      "description": "1:1 private message",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "chatId": { "type": "string", "description": "Unique ID for the pair, e.g., minId_maxId" }
      },
      "required": ["senderId", "receiverId", "content", "timestamp", "chatId"]
    },
    "Task": {
      "title": "Task",
      "description": "Work task tracked in the system",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "issueDate": { "type": "string" },
        "title": { "type": "string" },
        "objective": { "type": "string" },
        "assigneeId": { "type": "string" },
        "startDate": { "type": "string" },
        "expectedEndDate": { "type": "string" },
        "actualEndDate": { "type": "string" },
        "prevProgress": { "type": "string" },
        "currentUpdate": { "type": "string" },
        "status": { "type": "string", "enum": ["IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "CANCELLED", "ON_HOLD"] },
        "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
        "isHighlighted": { "type": "boolean" },
        "isLocked": { "type": "boolean" },
        "attachmentUrl": { "type": "string" },
        "attachmentName": { "type": "string" }
      },
      "required": ["code", "title", "assigneeId", "status", "priority"]
    },
    "ReportDraft": {
      "title": "ReportDraft",
      "description": "Draft content for monthly report",
      "type": "object",
      "properties": {
        "monthYear": { "type": "string" },
        "content": { "type": "string" },
        "userId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["monthYear", "content", "userId", "updatedAt"]
    },
    "OfficialReport": {
      "title": "OfficialReport",
      "description": "Finalized official monthly report snapshot",
      "type": "object",
      "properties": {
        "monthYear": { "type": "string" },
        "content": { "type": "string" },
        "userId": { "type": "string" },
        "stats": {
          "type": "object",
          "properties": {
            "total": { "type": "number" },
            "completed": { "type": "number" },
            "ongoing": { "type": "number" },
            "issues": { "type": "number" }
          }
        },
        "isOfficial": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["monthYear", "content", "userId", "stats", "isOfficial", "createdAt"]
    },
    "Presence": {
      "title": "Presence",
      "description": "User online status and activity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "lastActive": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["online", "offline"] }
      },
      "required": ["id", "name", "avatar", "lastActive", "status"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of staff members"
    },
    "messages": {
      "schema": "Message",
      "description": "Global chat messages"
    },
    "tasks": {
      "schema": "Task",
      "description": "Project tasks"
    },
    "direct_messages": {
      "schema": "PrivateMessage",
      "description": "1:1 private messages between users"
    },
    "report_drafts": {
      "schema": "ReportDraft",
      "description": "Monthly report drafts"
    },
    "official_reports": {
      "schema": "OfficialReport",
      "description": "Finalized monthly reports"
    },
    "presence": {
      "schema": "Presence",
      "description": "Real-time user presence tracking"
    }
  }
}
