{
  "entities": {
    "user": {
      "title": "User",
      "description": "System user profiles",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["Nhân Viên", "Trưởng Nhóm", "Trưởng Phòng", "Admin"] },
        "companyEmail": { "type": "string" },
        "personalEmail": { "type": "string" },
        "avatar": { "type": "string" },
        "code": { "type": "string" },
        "abbreviation": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "ACTIVE", "INACTIVE"] },
        "securityQuestion": { "type": "string" },
        "securityAnswer": { "type": "string" },
        "lastActive": { "type": "number" },
        "personalNote": { "type": "string" },
        "zalo": { "type": "string" }
      },
      "required": ["id", "name", "phone", "role", "companyEmail", "status"]
    },
    "task": {
      "title": "Task",
      "description": "Task management entity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "issueDate": { "type": "string" },
        "title": { "type": "string" },
        "objective": { "type": "string" },
        "assigneeId": { "type": "string" },
        "startDate": { "type": "string" },
        "expectedEndDate": { "type": "string" },
        "actualEndDate": { "type": "string" },
        "prevProgress": { "type": "string" },
        "currentUpdate": { "type": "string" },
        "status": { "type": "string", "enum": ["IN_PROGRESS", "PENDING_APPROVAL", "COMPLETED", "CANCELLED", "ON_HOLD"] },
        "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
        "isHighlighted": { "type": "boolean" },
        "isLocked": { "type": "boolean" },
        "updatedAt": { "type": "string" },
        "sortTimestamp": { "type": "number" },
        "attachmentUrl": { "type": "string" },
        "attachmentName": { "type": "string" },
        "reportExplanation": { "type": "string" },
        "reportAttachments": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "code", "title", "assigneeId", "status", "priority"]
    },
    "message": {
      "title": "Message",
      "description": "Chat message or comment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["authorId", "content"]
    },
    "directMessage": {
      "title": "Direct Message",
      "description": "One-to-one private message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "chatId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["senderId", "receiverId", "chatId", "content"]
    },
    "reportDraft": {
      "title": "Report Draft",
      "description": "Monthly report draft",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "monthYear": { "type": "string" },
        "content": { "type": "string" },
        "userId": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "officialReport": {
      "title": "Official Report",
      "description": "Finalized monthly report",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "monthYear": { "type": "string" },
        "content": { "type": "string" },
        "userId": { "type": "string" },
        "isOfficial": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "stats": {
          "type": "object",
          "properties": {
            "total": { "type": "number" },
            "completed": { "type": "number" },
            "ongoing": { "type": "number" },
            "issues": { "type": "number" }
          }
        }
      }
    }
  },
  "firestore": {
    "users": { "schema": "user", "description": "Users of the system" },
    "tasks": { "schema": "task", "description": "System tasks" },
    "messages": { "schema": "message", "description": "Global chat messages" },
    "direct_messages": { "schema": "directMessage", "description": "Private messages between users" },
    "report_drafts": { "schema": "reportDraft", "description": "User monthly report drafts" },
    "official_reports": { "schema": "officialReport", "description": "Submitted official reports" }
  }
}
