rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net (Deny all by default)
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Global Helpers
    // -------------------------------------------------------------------------
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data;
    }
    
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower()));
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() in [
          'lenhattruong.tpp@gmail.com',
          'club.nhuatanphu@gmail.com',
          'adminnutifood@gmail.com',
          'tanphuvietnam.tpp@gmail.com',
          'club.giadinhnho@gmail.com',
          'truong.le@tanphuvietnam.vn',
          'tan.vo@tanphuvietnam.vn'
        ] || (userExists() && getUserData().role == 'Admin')
      );
    }
    
    function isManager() {
      return isAdmin() || (isSignedIn() && userExists() && (getUserData().role == 'Leader' || getUserData().role == 'Staff'));
    }

    function isOwner(userId) {
      return isSignedIn() && (
        request.auth.uid == userId || 
        (request.auth.token.email.lower() == userId.lower())
      );
    }

    function isValidId(id) { 
      // Allow letters, numbers, underscore, dash, dot, and @ (for emails)
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.\\@]+$'); 
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 1. Connection & System
    match /test/{docId} {
      allow get: if true;
    }

    // 2. Users & Extra Users Collection
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && (isAdmin() || (userExists() && getUserData().delegatedPermissions.canManageStaff == true)) && isValidUser(incoming());
      allow update: if isSignedIn() && (
        isAdmin() || 
        (userExists() && getUserData().delegatedPermissions.canManageStaff == true) || 
        (isOwner(userId) && isSelfUpdate())
      ) && isValidUser(incoming());
      allow delete: if isAdmin();

      function isValidUser(data) {
        let requiredKeys = ['id', 'name', 'role', 'companyEmail', 'personalEmail', 'avatar', 'code', 'abbreviation', 'status'];
        return data.keys().hasAll(requiredKeys) &&
               data.id == userId &&
               isValidId(data.id) &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.role in ['Staff', 'Leader', 'Admin'] &&
               data.status in ['PENDING', 'ACTIVE', 'INACTIVE', 'DELETED'] &&
               data.companyEmail is string && data.companyEmail.size() <= 150 &&
               data.personalEmail is string && data.personalEmail.size() <= 150 &&
               data.avatar is string && data.avatar.size() <= 1000 &&
               data.code is string && data.code.size() <= 20 &&
               data.abbreviation is string && data.abbreviation.size() <= 10;
      }

      function isSelfUpdate() {
        return incoming().diff(existing()).affectedKeys().hasOnly(['lastActive', 'personalNote', 'securityQuestion', 'securityAnswer', 'status', 'avatar', 'name']);
      }
    }

    match /extra_users/{userId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // 3. Tasks Collection
    match /tasks/{taskId} {
      allow read, write: if isSignedIn();
      
      function isValidTask(data) {
        let requiredKeys = ['code', 'title', 'objective', 'assigneeId', 'status', 'priority', 'isHighlighted', 'isLocked'];
        return data.keys().hasAll(requiredKeys) &&
               data.code is string && data.code.size() <= 50 &&
               data.title is string && data.title.size() > 0 && data.title.size() <= 2000 &&
               data.objective is string && data.objective.size() <= 5000 &&
               data.assigneeId is string && data.assigneeId.size() <= 128 &&
               data.status in ['Chưa bắt đầu', 'Đang thực hiện', 'Hoàn thành', 'Tạm dừng', 'IN_PROGRESS', 'PENDING_APPROVAL', 'COMPLETED', 'CANCELLED', 'ON_HOLD', 'AWAITING_CONFIRMATION'] &&
               data.priority in ['Thấp', 'Trung bình', 'Cao', 'Khẩn cấp', 'LOW', 'MEDIUM', 'HIGH'] &&
               data.isHighlighted is bool &&
               data.isLocked is bool;
      }

      function isProgressUpdate() {
        return incoming().diff(existing()).affectedKeys().hasOnly(['currentUpdate', 'status', 'updatedAt', 'prevProgress', 'isNewSoldier']);
      }
    }

    // 4. Messages (Global Chat)
    match /messages/{messageId} {
      allow read, write: if isSignedIn();

      function isValidMessage(data) {
        return data.keys().hasAll(['authorId', 'content', 'timestamp']) &&
               data.content is string && data.content.size() > 0 && data.content.size() <= 2000 &&
               data.timestamp is timestamp;
      }
    }

    // 5. Direct Messages
    match /direct_messages/{msgId} {
      allow get: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // 6. Report Drafts
    match /report_drafts/{draftId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isManager());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isManager());
      allow write: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin()) && isValidDraft(incoming());

      function isValidDraft(data) {
        return data.keys().hasAll(['monthYear', 'userId', 'updatedAt']) &&
               data.userId is string &&
               data.monthYear is string && data.monthYear.size() <= 10;
      }
    }

    // 7. Official Reports
    match /official_reports/{reportId} {
      allow list: if isSignedIn() && resource.data.monthYear is string;
      allow get: if isSignedIn();
      allow create: if isManager() && isValidOfficialReport(incoming());
      allow delete: if isAdmin();

      function isValidOfficialReport(data) {
        return data.keys().hasAll(['monthYear', 'content', 'userId', 'isOfficial', 'createdAt']) &&
               data.monthYear is string &&
               data.isOfficial == true;
      }
    }

    // 8. System Logs
    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    // 9. Presence Collection
    match /presence/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) && isValidPresence(incoming());

      function isValidPresence(data) {
        return data.keys().hasAll(['id', 'name', 'status']) &&
               data.id == userId &&
               data.name is string && data.name.size() > 0 &&
               data.status in ['online', 'offline'];
      }
    }
    // 10. User Profiles Collection
    match /user_profiles/{userId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    // 11. Discussion Topics
    match /discussion_topics/{topicId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || existing().createdBy == request.auth.uid || existing().createdBy == 'SYSTEM');
      allow delete: if isAdmin();
    }

    // 12. Discussion Messages
    match /discussion_messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (existing().authorId == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || (existing().authorId == request.auth.uid);
    }
  }
}
