rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'truong.le@tanphuvietnam.vn' || 
        request.auth.token.email == 'lenhattruong.tpp@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
        get(/databases/$(database)/documents/extra_users/$(request.auth.uid)).data.role == 'Admin'
      );
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation Blueprints
    function isValidTopic(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.status in ['OPEN', 'CLOSED'] &&
             data.createdBy == request.auth.uid;
    }

    // Rules for Collections
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOwner(userId);
    }

    match /messages/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /discussion_topics/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || request.resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /discussion_messages/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    match /tasks/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'Leader']);
    }

    match /report_drafts/{id} {
      allow read, write: if isSignedIn();
    }

    match /official_reports/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /presence/{id} {
      allow read: if isSignedIn();
      allow write: if isOwner(id);
    }
  }
}
