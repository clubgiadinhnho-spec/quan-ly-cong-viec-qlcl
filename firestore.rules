rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && data.firebaseUid == request.auth.uid;
    }

    // 1. Users & UID Mapping
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        // Allow if document is unlinked
        (resource.data.firebaseUid == null || resource.data.firebaseUid == "") ||
        // Allow if this UID is mapped to this record
        (exists(/databases/$(database)/documents/uid_mapping/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/uid_mapping/$(request.auth.uid)).data.targetId == userId) ||
        // Allow if user is an admin
        isAdmin()
      );
    }

    match /uid_mapping/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == uid;
    }

    // Admin Helper (Optimized)
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/uid_mapping/$(request.auth.uid)) && 
             exists(/databases/$(database)/documents/users/$(get(/databases/$(database)/documents/uid_mapping/$(request.auth.uid)).data.targetId)) &&
             (
               get(/databases/$(database)/documents/users/$(get(/databases/$(database)/documents/uid_mapping/$(request.auth.uid)).data.targetId)).data.role in ['Admin', 'Trưởng Phòng', 'Quản lý', 'Phó Phòng']
             );
    }

    // 2. Tasks Collection
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        !resource.data.isLocked || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // 3. Messages & Direct Messages
    match /messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /direct_messages/{msgId} {
      allow read: if isSignedIn(); // Simplified for now to avoid complex queries in rules
      allow create: if isSignedIn();
    }

    // 4. Reports
    match /report_drafts/{draftId} {
      allow read, write: if isSignedIn();
    }

    match /official_reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

  }
}
