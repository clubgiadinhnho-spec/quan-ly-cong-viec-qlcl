rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Connection & System
    match /test/{docId} {
      allow get: if true;
    }

    // Phase 3: Global Helpers
    // -------------------------------------------------------------------------
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && (
        ('email' in request.auth.token && (
          request.auth.token.email == 'lenhattruong.tpp@gmail.com' ||
          request.auth.token.email == 'club.nhuatanphu@gmail.com' ||
          request.auth.token.email == 'adminnutifood@gmail.com' ||
          request.auth.token.email == 'tanphuvietnam.tpp@gmail.com' ||
          request.auth.token.email == 'club.giadinhnho@gmail.com'
        )) ||
        (userExists() && getUserData().role == 'Admin')
      );
    }
    
    function isManager() {
      return isAdmin() || (isSignedIn() && userExists() && (getUserData().role == 'Leader'));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 2. Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isAdmin() || getUserData().delegatedPermissions.canManageStaff == true || isOwner(userId)) && isValidUser(incoming());
      allow update: if isSignedIn() && (isAdmin() || getUserData().delegatedPermissions.canManageStaff == true || (isOwner(userId) && isSelfUpdate())) && isValidUser(incoming());
      allow delete: if isAdmin();

      function isValidUser(data) {
        return data.keys().hasAll(['id', 'name', 'role', 'companyEmail', 'personalEmail', 'avatar', 'code', 'abbreviation', 'status']) &&
               data.id == userId &&
               isValidId(data.id) &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.role in ['Staff', 'Leader', 'Admin'] &&
               data.status in ['PENDING', 'ACTIVE', 'INACTIVE', 'DELETED'] &&
               data.companyEmail is string && data.companyEmail.size() <= 150 &&
               data.personalEmail is string && data.personalEmail.size() <= 150 &&
               data.avatar is string && data.avatar.size() <= 1000 &&
               data.code is string && data.code.size() <= 20 &&
               data.abbreviation is string && data.abbreviation.size() <= 10 &&
               (data.keys().hasAny(['securityQuestion']) ? (data.securityQuestion is string && data.securityQuestion.size() <= 200) : true) &&
               (data.keys().hasAny(['securityAnswer']) ? (data.securityAnswer is string && data.securityAnswer.size() <= 100) : true);
      }

      function isSelfUpdate() {
        return incoming().diff(existing()).affectedKeys().hasOnly(['lastActive', 'personalNote', 'securityQuestion', 'securityAnswer', 'status', 'avatar', 'name']);
      }
    }

    // 3. Tasks Collection
    // -------------------------------------------------------------------------
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && (
        isAdmin() || 
        isManager() || 
        incoming().status == 'AWAITING_CONFIRMATION'
      ) && isValidTask(incoming());
      
      allow update: if (
        isSignedIn() && (
          isAdmin() || 
          isManager() || 
          (existing().assigneeId == request.auth.uid && isProgressUpdate())
        ) && 
        isValidTask(incoming())
      );
      
      allow delete: if isSignedIn() && (isAdmin() || isManager());

      function isValidTask(data) {
        let requiredKeys = ['code', 'title', 'objective', 'assigneeId', 'startDate', 'expectedEndDate', 'status', 'priority', 'prevProgress', 'currentUpdate', 'isHighlighted', 'isLocked', 'updatedAt'];
        return data.keys().hasAll(requiredKeys) &&
               data.code is string && data.code.size() <= 20 &&
               data.title is string && data.title.size() > 0 && data.title.size() <= 2000 &&
               data.objective is string && data.objective.size() <= 5000 &&
               data.assigneeId is string && data.assigneeId.size() <= 128 &&
               data.startDate is string &&
               data.expectedEndDate is string &&
               data.status in ['Chưa bắt đầu', 'Đang thực hiện', 'Hoàn thành', 'Tạm dừng', 'IN_PROGRESS', 'PENDING_APPROVAL', 'COMPLETED', 'CANCELLED', 'ON_HOLD', 'AWAITING_CONFIRMATION'] &&
               data.priority in ['Thấp', 'Trung bình', 'Cao', 'Khẩn cấp', 'LOW', 'MEDIUM', 'HIGH'] &&
               data.prevProgress is string &&
               data.currentUpdate is string &&
               data.isHighlighted is bool &&
               data.isLocked is bool;
      }

      function isProgressUpdate() {
        return incoming().diff(existing()).affectedKeys().hasOnly(['currentUpdate', 'status', 'updatedAt', 'prevProgress', 'isNewSoldier']);
      }
    }

    // 4. Messages (Global Chat)
    // -------------------------------------------------------------------------
    match /messages/{messageId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      
      allow create: if isSignedIn() && (
        incoming().authorId == request.auth.uid || 
        (isAdmin() && incoming().authorId == 'system')
      ) && isValidMessage(incoming());
      allow delete: if isAdmin();

      function isValidMessage(data) {
        return data.keys().hasAll(['authorId', 'content', 'timestamp']) &&
               (data.authorId == request.auth.uid || (isAdmin() && data.authorId == 'system')) &&
               data.content is string && data.content.size() > 0 && data.content.size() <= 2000 &&
               data.timestamp is timestamp;
      }
    }

    // 5. Direct Messages
    // -------------------------------------------------------------------------
    match /direct_messages/{msgId} {
      allow read, write: if isSignedIn();
      allow list: if isSignedIn();
    }

    // 6. Report Drafts
    // -------------------------------------------------------------------------
    match /report_drafts/{draftId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isManager());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isManager());
      
      allow write: if isSignedIn() && incoming().userId == request.auth.uid && isValidDraft(incoming());

      function isValidDraft(data) {
        return data.keys().hasAll(['monthYear', 'content', 'userId', 'updatedAt']) &&
               data.userId == request.auth.uid &&
               data.monthYear is string && data.monthYear.size() <= 10 &&
               data.content is string && data.content.size() <= 100000 &&
               data.updatedAt is timestamp;
      }
    }

    // 7. Official Reports
    // -------------------------------------------------------------------------
    match /official_reports/{reportId} {
      allow list: if isSignedIn() && resource.data.monthYear is string;
      allow get: if isSignedIn();
      
      allow create: if isManager() && isValidOfficialReport(incoming());
      allow delete: if isAdmin();

      function isValidOfficialReport(data) {
        return data.keys().hasAll(['monthYear', 'content', 'userId', 'stats', 'isOfficial', 'createdAt']) &&
               data.monthYear is string && data.monthYear.size() <= 10 &&
               data.content is string && data.content.size() <= 500000 &&
               data.isOfficial == true &&
               data.createdAt is timestamp;
      }
    }

    // 8. System Logs
    // -------------------------------------------------------------------------
    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
