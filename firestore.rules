rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // HELPERS & PRIMITIVES
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isUserVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in [
          'truong.le@tanphuvietnam.vn',
          'lenhattruong.tpp@gmail.com',
          'lenhattruong.caphef1@gmail.com',
          'club.nhuatanphu@gmail.com',
          'tanphuvietnam.tpp@gmail.com',
          'truongln.tanhongngoc@gmail.com',
          'lenhattruong.ddt@gmail.com'
        ]
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // VALIDATION BLUEPRINTS
    // -------------------------------------------------------------------------

    function isValidTask(data) {
      return data.keys().hasAll(['code', 'title', 'assigneeId', 'status']) &&
             data.keys().size() <= 30 && // Allow for optional fields but cap it
             data.code is string && data.code.size() <= 64 &&
             data.title is string && data.title.size() <= 1000 &&
             data.assigneeId is string && data.assigneeId.size() <= 128 &&
             data.status in ['IN_PROGRESS', 'PENDING', 'PENDING_APPROVAL', 'APPROVED', 'COMPLETED', 'CANCELLED', 'ON_HOLD', 'Hoàn thành', 'Đang thực hiện', 'DELETED', 'AWAITING_CONFIRMATION'];
    }

    function isValidUser(data) {
       return data.keys().hasAll(['name', 'role', 'status']) &&
              data.keys().size() <= 25 &&
              data.name is string && data.name.size() <= 200 &&
              data.role in ['Staff', 'Leader', 'Admin', 'Trưởng Phòng', 'Nhân viên'] &&
              data.status in ['ACTIVE', 'INACTIVE', 'PENDING'];
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['authorId', 'content', 'timestamp']) &&
             data.keys().size() <= 10 &&
             data.authorId is string && data.authorId.size() <= 128 &&
             data.content is string && data.content.size() <= 20000;
    }

    // -------------------------------------------------------------------------
    // COLLECTION MATCH BLOCKS
    // -------------------------------------------------------------------------

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. User Profiles
    match /user_profiles/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isValidId(userId) && isValidUser(incoming()) && (
        isAdmin() || (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'personalNote', 'phone', 'zalo', 'securityQuestion', 'securityAnswer', 'reminderSettings']))
      );
      allow delete: if isAdmin();
    }

    // 2. Extra Users
    match /extra_users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOwner(userId);
    }

    // 3. Tasks
    match /tasks/{taskId} {
      allow get: if isSignedIn() && isValidId(taskId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(taskId) && isValidTask(incoming()) && (
        isAdmin() || (incoming().status == 'PENDING' && incoming().waitingApproval == false)
      );
      allow update: if isSignedIn() && isValidId(taskId) && isValidTask(incoming()) && (
        isAdmin() || (
          // Allow assignee to update progress
          (existing().assigneeId == request.auth.uid || existing().authorId == request.auth.uid) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['currentUpdate', 'prevProgress', 'status', 'waitingApproval', 'lastActionAt', 'updatedAt', 'comments', 'requestUndo', 'requestDelete', 'lastUpdatedBy', 'lastUpdatedByRole', 'isNewUpdate'])
        )
      );
      allow delete: if isAdmin();
    }

    // 4. Messages
    match /messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidMessage(incoming()) && incoming().authorId == request.auth.uid;
      allow update: if isAdmin() || (isOwner(existing().authorId) && incoming().authorId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // 5. Discussion
    match /discussion_topics/{topicId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Allow any signed in to create topics
    }
    match /discussion_messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidMessage(incoming()) && incoming().authorId == request.auth.uid;
      allow update: if isAdmin() || isOwner(existing().authorId);
      allow delete: if isAdmin();
    }

    // 6. Direct Messages
    match /direct_messages/{msgId} {
      allow read: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // 7. Presence
    match /presence/{id} {
      allow read: if isSignedIn();
      allow write: if isOwner(id);
    }

    // 8. Reports
    match /report_drafts/{draftId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow write: if isSignedIn() && (isAdmin() || incoming().userId == request.auth.uid);
    }
    match /official_reports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 9. System
    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /task_categories/{catId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 10. Notifications
    match /notifications/{notifId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

  }
}
