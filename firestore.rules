rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.matches('(?i)truong.le@tanphuvietnam.vn') || 
        request.auth.token.email.matches('(?i)lenhattruong.tpp@gmail.com') ||
        request.auth.token.email.matches('(?i)lenhattruong.caphef1@gmail.com') ||
        request.auth.token.email.matches('(?i)club.nhuatanphu@gmail.com') ||
        request.auth.token.email.matches('(?i)tanphuvietnam.tpp@gmail.com') ||
        request.auth.token.email.matches('(?i)truongln.tanhongngoc@gmail.com') ||
        request.auth.token.email.matches('(?i)lenhattruong.ddt@gmail.com')
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['code', 'title', 'assigneeId', 'status']) &&
             data.code is string && data.code.size() <= 50 &&
             data.title is string && data.title.size() <= 500 &&
             (data.status in ['IN_PROGRESS', 'PENDING_APPROVAL', 'COMPLETED', 'CANCELLED', 'ON_HOLD', 'Hoàn thành', 'Đang thực hiện', 'Chưa bắt đầu', 'Tạm dừng', 'AWAITING_CONFIRMATION', 'PENDING', 'APPROVED', 'DELETED']);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['authorId', 'content', 'timestamp']) &&
             data.authorId is string && data.authorId.size() <= 128 &&
             data.content is string && data.content.size() <= 5000;
    }

    // 1. User Profiles - Allow profile read/write for matched users (Auto-Sync compatibility)
    match /user_profiles/{profileId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    // Global Access Control fallback
    match /{document=**} {
      allow read, write, delete: if isAdmin();
    }

    // 2. Extra Users (Auto-registration fallback)
    match /extra_users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && userId == request.auth.uid);
    }

    // 3. Tasks
    match /tasks/{taskId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidTask(incoming());
      allow update: if isSignedIn() && isValidTask(incoming());
      allow delete: if isAdmin();
    }

    // 4. Messages (General Chat)
    match /messages/{msgId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidMessage(incoming()) && incoming().authorId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid && incoming().authorId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // 5. Discussion
    match /discussion_topics/{topicId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /discussion_messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidMessage(incoming()) && incoming().authorId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // 6. Direct Messages
    match /direct_messages/{msgId} {
      allow list: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow get: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
      allow update: if isSignedIn() && (existing().senderId == request.auth.uid || existing().receiverId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // 7. Presence
    match /presence/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && id == request.auth.uid;
    }

    // 8. Reports
    match /report_drafts/{draftId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow write: if isSignedIn() && (isAdmin() || incoming().userId == request.auth.uid);
    }
    match /official_reports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /kpi_configs/{configId} {
      allow read, write: if isSignedIn();
    }

    // 9. System
    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 10. Notifications
    match /notifications/{notifId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // 11. Task Categories
    match /task_categories/{catId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

  }
}
